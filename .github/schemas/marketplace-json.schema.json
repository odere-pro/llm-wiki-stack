{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/odere-pro/llm-wiki-stack/schemas/marketplace-json.schema.json",
  "title": "llm-wiki-stack marketplace manifest",
  "description": "Minimal shape check for .claude-plugin/marketplace.json. Replace with Anthropic's published schema once available.",
  "type": "object",
  "required": ["name", "owner", "plugins"],
  "properties": {
    "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "owner": {
      "type": "object",
      "required": ["name", "url"],
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "source", "version"],
        "properties": {
          "name": { "type": "string" },
          "source": { "type": "string" },
          "description": { "type": "string" },
          "version": { "type": "string" },
          "license": { "type": "string" },
          "homepage": { "type": "string", "format": "uri" }
        }
      }
    }
  },
  "additionalProperties": true
}
